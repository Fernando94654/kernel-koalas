# Copy to .env and fill in your keys.

# MongoDB Atlas connection string (required)
# Get it from: Atlas > Deployment > Database > Connect > Drivers > Node.js
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/order-rescue?retryWrites=true&w=majority

# LLM API keys (optional — chatbot works without them, shows a friendly message)
# Groq (primary): https://console.groq.com  -> starts with gsk_
GROQ_API_KEY=
# Google AI Studio (fallback): https://aistudio.google.com -> starts with AIzaSy
GEMINI_API_KEY=
