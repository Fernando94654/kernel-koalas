# Copy to .env and fill in your keys.

# MongoDB Atlas connection string (required)
# Get it from: Atlas > Deployment > Database > Connect > Drivers > Node.js
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/order-rescue?retryWrites=true&w=majority

# Google OAuth (required for login)
# 1. Go to console.cloud.google.com → APIs & Services → Credentials → Create OAuth Client ID
# 2. Application type: Web application
# 3. Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
#    (add your deployed URL too: https://your-domain.com/api/auth/callback/google)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                    # generate with: openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LLM API keys (optional — chatbot works without them, shows a friendly message)
# Groq (primary): https://console.groq.com  -> starts with gsk_
GROQ_API_KEY=
# Google AI Studio (fallback): https://aistudio.google.com -> starts with AIzaSy
GEMINI_API_KEY=
